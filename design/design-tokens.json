{
  "designTokens": {
    "colors": {
      "background": "#0b0e14",
      "panel": "#131722",
      "accent": "#4da3ff",
      "success": "#39d353",
      "warning": "#ffb454",
      "error": "#ff6b6b",
      "textPrimary": "#ffffff",
      "textSecondary": "#8b949e",
      "border": "#21262d",
      "channelColors": [
        "#ff6b6b",
        "#4ecdc4",
        "#45b7d1",
        "#96ceb4",
        "#feca57",
        "#ff9ff3",
        "#54a0ff",
        "#5f27cd",
        "#00d2d3",
        "#ff9f43",
        "#10ac84",
        "#ee5a24"
      ]
    },
    "typography": {
      "header": {
        "fontSize": 16,
        "fontWeight": "bold",
        "lineHeight": 1.5
      },
      "body": {
        "fontSize": 14,
        "fontWeight": "normal",
        "lineHeight": 1.4
      },
      "small": {
        "fontSize": 12,
        "fontWeight": "normal",
        "lineHeight": 1.3
      },
      "monospace": {
        "fontSize": 12,
        "fontFamily": "Monaco, Consolas, monospace",
        "lineHeight": 1.2
      }
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48
    },
    "dimensions": {
      "controlPanelWidth": 300,
      "minWindowWidth": 1000,
      "minWindowHeight": 700,
      "headerHeight": 60,
      "panelPadding": 16,
      "buttonHeight": 40,
      "inputHeight": 36
    }
  },
  "components": {
    "TimeSeriesPanel": {
      "defaultChannels": 8,
      "maxChannels": 16,
      "timeWindow": 10,
      "showLegend": true,
      "showGrid": true,
      "scaleOptions": [25, 50, 100, 200, 500],
      "defaultScale": 100,
      "scrollSpeed": 1
    },
    "FFTPanel": {
      "maxFrequency": 60,
      "defaultMaxFreq": 50,
      "scaleMode": "log",
      "showPeaks": true,
      "bandOverlay": true,
      "frequencyBands": {
        "delta": [0.5, 4],
        "theta": [4, 8],
        "alpha": [8, 13],
        "beta": [13, 30],
        "gamma": [30, 60]
      }
    },
    "BandPowerPanel": {
      "bands": ["delta", "theta", "alpha", "beta", "gamma"],
      "displayMode": "tiles",
      "showValues": true,
      "powerUnit": "dB",
      "updateRate": 5,
      "colorCoding": true
    },
    "SpectrogramPanel": {
      "timeWindow": 30,
      "maxFrequency": 60,
      "frequencyResolution": 0.5,
      "colormap": "viridis",
      "channelGrouping": "hemisphere",
      "intensityRange": [-60, 20]
    },
    "ControlPanel": {
      "sections": ["device", "channels", "filters", "networking", "recording"],
      "collapsible": true,
      "minWidth": 250,
      "maxWidth": 400
    }
  },
  "states": {
    "application": ["idle", "connecting", "streaming", "recording", "error"],
    "panels": ["loading", "active", "paused", "error"]
  },
  "interactions": {
    "channelToggle": {
      "method": "click",
      "feedback": "visual",
      "duration": 200
    },
    "scaleAdjust": {
      "method": "mousewheel",
      "sensitivity": 1.1,
      "limits": [10, 1000]
    },
    "panelResize": {
      "enabled": true,
      "minSize": 200,
      "gripSize": 8
    },
    "timeNavigation": {
      "enabled": true,
      "scrubbing": true,
      "playback": true
    }
  }
}
